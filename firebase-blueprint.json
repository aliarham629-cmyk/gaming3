{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for a user",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "APIKey": {
      "title": "Gemini API Key",
      "description": "Stores Gemini API keys for rotation",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "exhausted", "invalid"] },
        "usageCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "status", "createdAt"]
    },
    "Website": {
      "title": "WordPress Website",
      "description": "Credentials for WordPress REST API",
      "type": "object",
      "properties": {
        "siteUrl": { "type": "string" },
        "username": { "type": "string" },
        "appPassword": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["siteUrl", "username", "appPassword", "createdAt"]
    },
    "KeywordBatch": {
      "title": "Keyword Batch",
      "description": "A batch of keywords added by the user",
      "type": "object",
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "processing", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["keywords", "status", "createdAt"]
    },
    "Article": {
      "title": "Generated Article",
      "description": "An AI-generated article and its metadata",
      "type": "object",
      "properties": {
        "keyword": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "metaDescription": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled", "error"] },
        "websiteId": { "type": "string" },
        "wpPostId": { "type": "string" },
        "batchId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "schemaMarkup": { "type": "string" },
        "error": { "type": "string" }
      },
      "required": ["keyword", "title", "content", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/apiKeys/{keyId}": {
      "schema": "APIKey",
      "description": "User's Gemini API keys"
    },
    "/users/{userId}/websites/{siteId}": {
      "schema": "Website",
      "description": "User's connected WordPress websites"
    },
    "/users/{userId}/batches/{batchId}": {
      "schema": "KeywordBatch",
      "description": "User's keyword batches"
    },
    "/users/{userId}/articles/{articleId}": {
      "schema": "Article",
      "description": "Articles generated by the user"
    }
  }
}
